---
import { GITHUB_URL } from '../config';
const { pathname } = Astro.url;
const links = [
  { href: '/', label: 'Home' },
  { href: '/learn/', label: 'Learn' },
  { href: '/downloads/', label: 'Downloads' },
  { href: '/tracker/', label: 'Tracker' },
  { href: '/contribute/', label: 'Contribute' },
];
const isActive = (href: string) => {
  if (href === '/') return pathname === '/' || pathname === '';
  return pathname === href || pathname === href.replace(/\/$/, '');
};
---
<nav class="nav">
  <div class="nav-inner">
    <a href="/" class="nav-brand">
      <img src="/logo.png" alt="DeckNForge logo" />
      <span>DeckNForge</span>
    </a>
    <div class="nav-links">
      {links.map((l) => (
        <a href={l.href} class={isActive(l.href) ? 'active' : ''}>{l.label}</a>
      ))}
      <a href={GITHUB_URL} target="_blank" rel="noopener" class="nav-github" aria-label="GitHub repository" title="GitHub">
        <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true" fill="currentColor">
          <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.55 0-.27-.01-1.18-.02-2.13-3.2.7-3.87-1.36-3.87-1.36-.52-1.32-1.27-1.67-1.27-1.67-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.02 1.75 2.68 1.25 3.34.96.1-.74.4-1.25.72-1.54-2.55-.29-5.24-1.28-5.24-5.7 0-1.26.45-2.29 1.18-3.1-.12-.29-.51-1.46.11-3.04 0 0 .96-.31 3.16 1.18.92-.26 1.9-.39 2.88-.39.98 0 1.96.13 2.88.39 2.2-1.49 3.16-1.18 3.16-1.18.62 1.58.23 2.75.11 3.04.74.81 1.18 1.84 1.18 3.1 0 4.43-2.7 5.41-5.27 5.69.41.36.78 1.06.78 2.13 0 1.54-.01 2.78-.01 3.16 0 .31.21.67.79.55C20.21 21.39 23.5 17.08 23.5 12 23.5 5.65 18.35.5 12 .5z"/>
        </svg>
      </a>
    </div>
  </div>
</nav>
