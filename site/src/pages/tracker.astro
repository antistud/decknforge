---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Tracker — DeckNForge">
  <section class="section">
    <div class="container">
      <h1 class="center" style="margin-bottom:18px; background:none; color:var(--ink); -webkit-text-fill-color:var(--ink); filter:none;">Dungeon Tracker</h1>

      <div class="card">
        <div class="grid cols-2">
          <div class="stat" style="padding:0; border:0;">
            <div class="stat-label">Round</div>
            <div class="stepper">
              <button id="round-dec" type="button" aria-label="-1 round">−</button>
              <span id="round-val" class="val">1</span>
              <button id="round-inc" type="button" aria-label="+1 round">+</button>
            </div>
          </div>
          <div class="stat" style="padding:0; border:0;">
            <div class="stat-label">Glory</div>
            <div class="stepper">
              <button data-glory="-1" type="button" aria-label="-1 Glory">−</button>
              <span id="glory-val" class="val">0</span>
              <button data-glory="1" type="button" aria-label="+1 Glory">+</button>
            </div>
          </div>
        </div>
      </div>

      <div class="card">
        <div class="list-item-head">
          <div class="list-item-name">Boss</div>
          <div style="display:flex; gap:8px; align-items:center; flex-wrap:wrap;">
            <label class="text-dim" for="boss-max" style="font-size:0.85rem;">Max</label>
            <input id="boss-max" type="number" min="0" placeholder="HP" style="max-width:80px;" />
            <button id="boss-heal" class="icon-btn" type="button">Heal</button>
          </div>
        </div>
        <div class="hp-bar"><span id="boss-hp-bar" style="width:0%"></span></div>
        <div class="stat" style="border:0; padding-top:10px;">
          <div class="stat-label">HP</div>
          <div class="stepper">
            <button data-boss-hp="-10" type="button" aria-label="-10 HP">−10</button>
            <button data-boss-hp="-5" type="button" aria-label="-5 HP">−5</button>
            <button data-boss-hp="-1" type="button" aria-label="-1 HP">−1</button>
            <span id="boss-hp" class="val big">0</span>
            <button data-boss-hp="1" type="button" aria-label="+1 HP">+1</button>
            <button data-boss-hp="5" type="button" aria-label="+5 HP">+5</button>
          </div>
        </div>
      </div>

      <div class="card">
        <div class="list-item-head">
          <div class="list-item-name">Wizards</div>
          <button id="add-wizard" class="icon-btn" type="button">+ Add</button>
        </div>
        <div id="wizards-list"></div>
      </div>

      <div class="card">
        <div class="list-item-head">
          <div class="list-item-name">Monsters</div>
          <button id="add-monster" class="icon-btn" type="button">+ Add</button>
        </div>
        <div id="monsters-list"></div>
      </div>

      <div class="reset-row">
        <span id="autosave-indicator" class="text-dim" title="Tracker autosaves to your browser. Refresh, close the tab, and come back — your dungeon is still here.">
          <svg viewBox="0 0 16 16" width="14" height="14" fill="currentColor" aria-hidden="true" style="vertical-align:-2px;">
            <path d="M8 1.5a6.5 6.5 0 1 0 0 13 6.5 6.5 0 0 0 0-13zM7.5 4a.5.5 0 0 1 1 0v4.293l2.354 2.353a.5.5 0 0 1-.708.708L7.146 8.854a.5.5 0 0 1-.146-.354V4z"/>
          </svg>
          Autosaved
        </span>
        <button id="reset-all" class="icon-btn danger" type="button" aria-label="Reset tracker">Reset</button>
      </div>
    </div>
  </section>

  <script is:inline>
    (function () {
      'use strict';
      const KEY = 'decknforge.tracker.v2';
      const WIZARD_HP = 20;
      const MONSTER_HP = 10;

      function makeId() { return Math.random().toString(36).slice(2, 9); }
      function clamp(n, lo, hi) { return Math.max(lo, Math.min(hi, n)); }

      const defaultState = () => ({
        round: 1,
        glory: 0,
        bossHp: 0,
        bossMaxHp: 0,
        wizards: [],
        monsters: [],
      });

      let state = load();

      function load() {
        try {
          const raw = localStorage.getItem(KEY);
          if (!raw) return defaultState();
          const parsed = JSON.parse(raw);
          return Object.assign(defaultState(), parsed);
        } catch (e) { return defaultState(); }
      }

      let savedTimer = null;
      function flashSaved() {
        const el = document.getElementById('autosave-indicator');
        if (!el) return;
        el.classList.add('saved-flash');
        if (savedTimer) clearTimeout(savedTimer);
        savedTimer = setTimeout(() => el.classList.remove('saved-flash'), 600);
      }

      function save() {
        try { localStorage.setItem(KEY, JSON.stringify(state)); flashSaved(); } catch (e) {}
      }

      // Round
      document.getElementById('round-inc').addEventListener('click', () => {
        state.round = Math.min(20, state.round + 1); save(); render();
      });
      document.getElementById('round-dec').addEventListener('click', () => {
        state.round = Math.max(1, state.round - 1); save(); render();
      });

      // Glory
      document.querySelectorAll('[data-glory]').forEach(el => {
        el.addEventListener('click', () => {
          state.glory = Math.max(0, state.glory + parseInt(el.dataset.glory, 10));
          save(); render();
        });
      });

      // Boss HP
      document.querySelectorAll('[data-boss-hp]').forEach(el => {
        el.addEventListener('click', () => {
          state.bossHp = clamp(state.bossHp + parseInt(el.dataset.bossHp, 10), 0, 9999);
          save(); render();
        });
      });
      const bossMaxInput = document.getElementById('boss-max');
      bossMaxInput.addEventListener('input', () => {
        const v = parseInt(bossMaxInput.value, 10);
        state.bossMaxHp = isNaN(v) ? 0 : Math.max(0, v);
        if (state.bossMaxHp > 0 && state.bossHp > state.bossMaxHp) state.bossHp = state.bossMaxHp;
        if (state.bossMaxHp > 0 && state.bossHp === 0) state.bossHp = state.bossMaxHp;
        save(); render();
      });
      document.getElementById('boss-heal').addEventListener('click', () => {
        state.bossHp = state.bossMaxHp;
        save(); render();
      });

      // Add wizard / monster
      document.getElementById('add-wizard').addEventListener('click', () => {
        state.wizards.push({ id: makeId(), hp: WIZARD_HP });
        save(); render();
      });
      document.getElementById('add-monster').addEventListener('click', () => {
        state.monsters.push({ id: makeId(), hp: MONSTER_HP });
        save(); render();
      });

      // Reset
      document.getElementById('reset-all').addEventListener('click', () => {
        if (!confirm('Reset everything?\n\nClears wizards, monsters, boss HP, round, and glory.')) return;
        state = defaultState();
        document.getElementById('boss-max').value = '';
        save(); render();
      });

      // Per-row delegated actions
      document.body.addEventListener('click', (e) => {
        const btn = e.target.closest('button[data-action]');
        if (!btn) return;
        const id = btn.dataset.id;
        const action = btn.dataset.action;
        const d = parseInt(btn.dataset.d || '0', 10);
        if (action === 'wiz-hp') {
          const w = state.wizards.find(w => w.id === id);
          if (w) { w.hp = clamp(w.hp + d, 0, 99); save(); render(); }
        } else if (action === 'wiz-remove') {
          state.wizards = state.wizards.filter(w => w.id !== id);
          save(); render();
        } else if (action === 'mon-hp') {
          const m = state.monsters.find(m => m.id === id);
          if (m) { m.hp = clamp(m.hp + d, 0, 9999); save(); render(); }
        } else if (action === 'mon-remove') {
          state.monsters = state.monsters.filter(m => m.id !== id);
          save(); render();
        }
      });

      function renderBoss() {
        document.getElementById('boss-hp').textContent = state.bossHp;
        const maxEl = document.getElementById('boss-max');
        if (document.activeElement !== maxEl) {
          maxEl.value = state.bossMaxHp || '';
        }
        const pct = state.bossMaxHp > 0 ? clamp(state.bossHp / state.bossMaxHp * 100, 0, 100) : 0;
        document.getElementById('boss-hp-bar').style.width = pct + '%';
      }

      function renderWizards() {
        const list = document.getElementById('wizards-list');
        list.innerHTML = '';
        if (state.wizards.length === 0) {
          list.innerHTML = '<div class="text-dim center" style="padding:12px 0;">No wizards yet. Tap + Add.</div>';
          return;
        }
        state.wizards.forEach((w, i) => {
          const row = document.createElement('div');
          row.className = 'tracker-row';
          row.innerHTML = `
            <div class="tracker-row-label">Wizard ${i + 1}</div>
            <div class="hp-bar"><span style="width:${clamp(w.hp / WIZARD_HP * 100, 0, 100)}%"></span></div>
            <div class="stepper">
              <button data-action="wiz-hp" data-id="${w.id}" data-d="-5" type="button" aria-label="-5 HP">−5</button>
              <button data-action="wiz-hp" data-id="${w.id}" data-d="-1" type="button" aria-label="-1 HP">−1</button>
              <span class="val">${w.hp}</span>
              <button data-action="wiz-hp" data-id="${w.id}" data-d="1"  type="button" aria-label="+1 HP">+1</button>
              <button data-action="wiz-hp" data-id="${w.id}" data-d="5"  type="button" aria-label="+5 HP">+5</button>
            </div>
            <button class="icon-btn danger" data-action="wiz-remove" data-id="${w.id}" type="button" aria-label="Remove wizard">×</button>
          `;
          list.appendChild(row);
        });
      }

      function renderMonsters() {
        const list = document.getElementById('monsters-list');
        list.innerHTML = '';
        if (state.monsters.length === 0) {
          list.innerHTML = '<div class="text-dim center" style="padding:12px 0;">No monsters. Tap + Add.</div>';
          return;
        }
        state.monsters.forEach((m, i) => {
          const row = document.createElement('div');
          row.className = 'tracker-row';
          row.innerHTML = `
            <div class="tracker-row-label">Monster ${i + 1}</div>
            <div class="stepper">
              <button data-action="mon-hp" data-id="${m.id}" data-d="-5" type="button" aria-label="-5 HP">−5</button>
              <button data-action="mon-hp" data-id="${m.id}" data-d="-1" type="button" aria-label="-1 HP">−1</button>
              <span class="val">${m.hp}</span>
              <button data-action="mon-hp" data-id="${m.id}" data-d="1"  type="button" aria-label="+1 HP">+1</button>
              <button data-action="mon-hp" data-id="${m.id}" data-d="5"  type="button" aria-label="+5 HP">+5</button>
            </div>
            <button class="icon-btn danger" data-action="mon-remove" data-id="${m.id}" type="button" aria-label="Remove monster">×</button>
          `;
          list.appendChild(row);
        });
      }

      function render() {
        document.getElementById('round-val').textContent = state.round;
        document.getElementById('glory-val').textContent = state.glory;
        renderBoss();
        renderWizards();
        renderMonsters();
      }

      render();
    })();
  </script>
</Layout>
